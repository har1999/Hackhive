# KaamSetu Environment Variables
# Copy this file to .env and fill in values

SECRET_KEY=django-insecure-kaamsetu-change-this-in-production-immediately
DEBUG=True
ALLOWED_HOSTS=*

# Database (SQLite default for dev, PostgreSQL for prod)
# DATABASE_URL=postgresql://user:password@localhost:5432/kaamsetu

# Redis (for Celery task queue)
# REDIS_URL=redis://localhost:6379/0

# SMS Provider: 'console' (dev) | 'fast2sms' | 'twilio'
SMS_PROVIDER=console
FAST2SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
